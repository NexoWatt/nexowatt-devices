{
  "type": "tabs",
  "items": {
    "general": {
      "type": "panel",
      "label": {
        "en": "General",
        "de": "Allgemein"
      },
      "items": {
        "_alive": {
          "type": "alive",
          "label": {
            "en": "Instance status",
            "de": "Instanz-Status"
          },
          "textAlive": {
            "en": "Instance %s is alive",
            "de": "Instanz %s läuft"
          },
          "textNotAlive": {
            "en": "Instance %s is not alive",
            "de": "Instanz %s läuft nicht"
          },
          "newLine": true
        },
        "_headline_poll": {
          "type": "staticText",
          "text": {
            "en": "Global polling settings (applies to polling drivers like Modbus/HTTP/UDP; event-driven drivers ignore it).",
            "de": "Globale Polling-Einstellungen (für Polling-Treiber wie Modbus/HTTP/UDP; Event-basierte Treiber ignorieren es)."
          },
          "newLine": true
        },
        "pollIntervalMs": {
          "type": "number",
          "label": {
            "en": "Global polling interval (ms)",
            "de": "Globales Polling-Intervall (ms)"
          },
          "min": 250,
          "max": 600000,
          "sm": 6,
          "md": 4,
          "newLine": true
        },
        "modbusTimeoutMs": {
          "type": "number",
          "label": {
            "en": "Default Modbus timeout (ms)",
            "de": "Standard Modbus-Timeout (ms)"
          },
          "min": 100,
          "max": 60000,
          "sm": 6,
          "md": 4
        },
        "registerAddressOffset": {
          "type": "number",
          "label": {
            "en": "Default register address offset",
            "de": "Standard Register-Adress-Offset"
          },
          "min": -100000,
          "max": 100000,
          "sm": 6,
          "md": 4,
          "newLine": true
        },
        "_hint_poll": {
          "type": "staticText",
          "text": {
            "en": "Tip: You can override polling interval and protocol timeouts per device in the Devices tab.",
            "de": "Tipp: Du kannst Polling-Intervall und Protokoll-Timeouts pro Gerät im Tab „Geräte“ überschreiben."
          },
          "newLine": true
        }
      }
    },
    "devicesTab": {
      "type": "panel",
      "label": {
        "en": "Devices",
        "de": "Geräte"
      },
      "items": {
        "_help0": {
          "type": "staticText",
          "text": {
            "en": "Add one or more devices below. If dropdown lists stay empty, ensure the adapter instance is running (Instance status in General tab).",
            "de": "Füge unten ein oder mehrere Geräte hinzu. Wenn Dropdown-Listen leer bleiben, stelle sicher, dass die Adapter-Instanz läuft (Status im Tab „Allgemein“)."
          },
          "newLine": true
        },
        "devices": {
          "type": "accordion",
          "label": {
            "en": "Configured devices",
            "de": "Konfigurierte Geräte"
          },
          "titleAttr": "id",
          "clone": "id",
          "items": [
            {
              "type": "checkbox",
              "attr": "enabled",
              "label": {
                "en": "Active",
                "de": "Aktiv"
              },
              "default": true,
              "sm": 3,
              "md": 2
            },
            {
              "type": "text",
              "attr": "id",
              "label": {
                "en": "Device ID (unique)",
                "de": "Geräte-ID (eindeutig)"
              },
              "sm": 5,
              "md": 3,
              "validator": "(() => { try { if (!data.id) return false; if (!globalData || !Array.isArray(globalData.devices)) return true; const id = String(data.id); const cnt = globalData.devices.filter(d => d && String(d.id) === id).length; return cnt <= 1; } catch (e) { return !!data.id; } })()"
            },
            {
              "type": "text",
              "attr": "name",
              "label": {
                "en": "Name (optional)",
                "de": "Name (optional)"
              },
              "sm": 4,
              "md": 4,
              "newLine": true
            },
            {
              "type": "selectSendTo",
              "attr": "category",
              "label": {
                "en": "Category",
                "de": "Kategorie"
              },
              "command": "getCategories",
              "manual": true,
              "noTranslation": true,
              "sm": 6,
              "md": 4,
              "validator": "!!data.category",
              "newLine": true
            },
            {
              "type": "selectSendTo",
              "attr": "manufacturer",
              "label": {
                "en": "Manufacturer",
                "de": "Hersteller"
              },
              "command": "getManufacturers",
              "jsonData": "{\"category\":\"${data.category}\"}",
              "alsoDependsOn": [
                "category"
              ],
              "manual": true,
              "noTranslation": true,
              "sm": 6,
              "md": 4,
              "validator": "!!data.manufacturer"
            },
            {
              "type": "autocompleteSendTo",
              "attr": "templateId",
              "label": {
                "en": "Driver / Template",
                "de": "Treiber / Template"
              },
              "command": "getTemplates",
              "jsonData": "{\"category\":\"${data.category}\",\"manufacturer\":\"${data.manufacturer}\"}",
              "alsoDependsOn": [
                "category",
                "manufacturer"
              ],
              "freeSolo": false,
              "noTranslation": true,
              "sm": 12,
              "validator": "!!data.templateId",
              "newLine": true
            },
            {
              "type": "selectSendTo",
              "attr": "protocol",
              "label": {
                "en": "Protocol",
                "de": "Protokoll"
              },
              "command": "getProtocols",
              "jsonData": "{\"templateId\":\"${data.templateId}\"}",
              "alsoDependsOn": [
                "templateId"
              ],
              "manual": true,
              "noTranslation": true,
              "sm": 6,
              "md": 4,
              "validator": "!!data.protocol",
              "newLine": true
            },
            {
              "type": "number",
              "attr": "pollIntervalMs",
              "label": {
                "en": "Polling interval (ms, optional)",
                "de": "Polling-Intervall (ms, optional)"
              },
              "min": 0,
              "max": 600000,
              "sm": 6,
              "md": 4,
              "helperText": {
                "en": "0 = use global/template default",
                "de": "0 = global/Template verwenden"
              }
            },
            {
              "type": "number",
              "attr": "heartbeatTimeoutMs",
              "label": {
                "en": "Heartbeat timeout (ms)",
                "de": "Heartbeat-Timeout (ms)"
              },
              "min": 1000,
              "max": 600000,
              "sm": 6,
              "md": 4,
              "helperText": {
                "en": "Used to mark device stale (0 = disabled).",
                "de": "Wird genutzt um „stale“ zu erkennen (0 = deaktiviert)."
              },
              "newLine": true
            },
            {
              "type": "divider",
              "newLine": true
            },
            {
              "type": "staticText",
              "text": {

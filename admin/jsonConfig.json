{
  "type": "tabs",
  "items": {
    "general": {
      "type": "panel",
      "label": "General",
      "items": {
        "_alive": {
          "type": "alive",
          "label": "Instance status",
          "textAlive": "Instance %s is alive",
          "textNotAlive": "Instance %s is not alive",
          "newLine": true
        },
        "_headline_poll": {
          "type": "staticText",
          "text": "Global polling settings (applies to polling drivers like Modbus/HTTP/UDP; event-driven drivers ignore it).",
          "newLine": true
        },
        "pollIntervalMs": {
          "type": "number",
          "label": "Global polling interval (ms)",
          "min": 250,
          "max": 600000,
          "sm": 6,
          "md": 4,
          "newLine": true
        },
        "modbusTimeoutMs": {
          "type": "number",
          "label": "Default Modbus timeout (ms)",
          "min": 100,
          "max": 60000,
          "sm": 6,
          "md": 4
        },
        "registerAddressOffset": {
          "type": "number",
          "label": "Default register address offset",
          "min": -100000,
          "max": 100000,
          "sm": 6,
          "md": 4,
          "newLine": true
        },
        "_hint_poll": {
          "type": "staticText",
          "text": "Tip: You can override polling interval and protocol timeouts per device in the Devices tab.",
          "newLine": true
        }
      }
    },
    "devicesTab": {
      "type": "panel",
      "label": "Devices",
      "items": {
        "_help0": {
          "type": "staticText",
          "text": "Add one or more devices below. If dropdown lists stay empty, ensure the adapter instance is running (Instance status in General tab).",
          "newLine": true
        },
        "devices": {
          "type": "accordion",
          "label": "Configured devices",
          "titleAttr": "id",
          "clone": "id",
          "items": [
            {
              "type": "checkbox",
              "attr": "enabled",
              "label": "Active",
              "default": true,
              "sm": 3,
              "md": 2
            },
            {
              "type": "text",
              "attr": "id",
              "label": "Device ID (unique)",
              "sm": 5,
              "md": 3,
              "validator": "(() => { try { if (!data.id) return false; if (!globalData || !Array.isArray(globalData.devices)) return true; const id = String(data.id); const cnt = globalData.devices.filter(d => d && String(d.id) === id).length; return cnt <= 1; } catch (e) { return !!data.id; } })()"
            },
            {
              "type": "text",
              "attr": "name",
              "label": "Name (optional)",
              "sm": 4,
              "md": 4,
              "newLine": true
            },
            {
              "type": "selectSendTo",
              "attr": "category",
              "label": "Category",
              "command": "getCategories",
              "manual": true,
              "noTranslation": true,
              "sm": 6,
              "md": 4,
              "validator": "!!data.category",
              "newLine": true
            },
            {
              "type": "selectSendTo",
              "attr": "manufacturer",
              "label": "Manufacturer",
              "command": "getManufacturers",
              "jsonData": "{\"category\":\"${data.category}\"}",
              "alsoDependsOn": [
                "category"
              ],
              "manual": true,
              "noTranslation": true,
              "sm": 6,
              "md": 4,
              "validator": "!!data.manufacturer"
            },
            {
              "type": "autocompleteSendTo",
              "attr": "templateId",
              "label": "Driver / Template",
              "command": "getTemplates",
              "jsonData": "{\"category\":\"${data.category}\",\"manufacturer\":\"${data.manufacturer}\"}",
              "alsoDependsOn": [
                "category",
                "manufacturer"
              ],
              "freeSolo": false,
              "noTranslation": true,
              "sm": 12,
              "validator": "!!data.templateId",
              "newLine": true
            },
            {
              "type": "selectSendTo",
              "attr": "protocol",
              "label": "Protocol",
              "command": "getProtocols",
              "jsonData": "{\"templateId\":\"${data.templateId}\"}",
              "alsoDependsOn": [
                "templateId"
              ],
              "manual": true,
              "noTranslation": true,
              "sm": 6,
              "md": 4,
              "validator": "!!data.protocol",
              "newLine": true
            },
            {
              "type": "number",
              "attr": "pollIntervalMs",
              "label": "Polling interval (ms, optional)",
              "min": 0,
              "max": 600000,
              "sm": 6,
              "md": 4,
              "helperText": "0 = use global/template default"
            },
            {
              "type": "number",
              "attr": "heartbeatTimeoutMs",
              "label": "Heartbeat timeout (ms)",
              "min": 1000,
              "max": 600000,
              "sm": 6,
              "md": 4,
              "helperText": "Used to mark device stale (0 = disabled).",
              "newLine": true
            },
            {
              "type": "divider",
              "newLine": true
            },
            {
              "type": "staticText",
              "text": "Modbus TCP connection",
              "hidden": "data.protocol !== 'modbusTcp'",
              "newLine": true
            },
            {
              "type": "text",
              "attr": "connection.host",
              "label": "Host / IP",
              "hidden": "data.protocol !== 'modbusTcp'",
              "sm": 6,
              "md": 4,
              "newLine": true
            },
            {
              "type": "port",
              "attr": "connection.port",
              "label": "Port",
              "hidden": "data.protocol !== 'modbusTcp'",
              "default": 502,
              "sm": 3,
              "md": 2
            },
            {
              "type": "number",
              "attr": "connection.unitId",
